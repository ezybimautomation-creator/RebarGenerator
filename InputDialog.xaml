<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ToolsByGimhan.RebarGenerator.InputDialog"
        Title="Input" Height="145" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="PromptText" Grid.Row="0" Text="Enter value:"
                   TextWrapping="Wrap"/>
        <TextBox x:Name="InputBox" Grid.Row="2" Padding="4"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"     Width="80" Margin="0,0,8,0"
                    Click="OkClick"     IsDefault="True"/>
            <Button Content="Cancel" Width="80"
                    Click="CancelClick" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
